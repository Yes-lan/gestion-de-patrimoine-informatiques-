{% extends 'base.html.twig' %}

{% block title %}Recherche Opération{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
  <h2>Recherche et Gestion des Opérations</h2>
  {% if is_granted('ROLE_MEDECIN') or is_granted('ROLE_INFIRMIERE') or is_granted('ROLE_ADMIN') %}
    <a href="{{ path('operation_creer') }}" class="btn btn-success">
      <i class="bi bi-plus-circle"></i> Créer une opération
    </a>
  {% endif %}
</div>

<div class="card shadow-sm">
  <div class="card-body">
    <h5 class="card-title mb-3">Recherche d'opérations</h5>

    <form id="operationForm" class="row g-2 align-items-end">
      <div class="col-md-6">
        <label class="form-label visually-hidden" for="q">Titre ou patient</label>
        <input id="q" name="q" type="search" class="form-control" placeholder="Titre de l'opération ou nom/prénom du patient">
      </div>

      <div class="col-md-2">
        <label class="form-label" for="date_from">Depuis</label>
        <input id="date_from" name="date_from" type="date" class="form-control">
      </div>

      <div class="col-md-2">
        <label class="form-label" for="date_to">Jusqu'à</label>
        <input id="date_to" name="date_to" type="date" class="form-control">
      </div>

      <div class="col-md-2 d-grid">
        <button id="searchBtn" type="button" class="btn btn-primary">Rechercher</button>
      </div>
    </form>
  </div>
</div>

<div id="results" class="mt-4">
  {% if operations is defined %}
    {% if operations is empty %}
      <div class="alert alert-secondary">Aucun résultat.</div>
    {% else %}
      <div class="row g-3">
        {% for operation in operations %}
          <div class="col-md-4">
            <div class="card h-100">
              <div class="card-body d-flex flex-column">
                <h6 class="card-title mb-1">
                  <a href="{{ path('operation_afficher', {'id': operation.id}) }}">{{ operation.titre }}</a>
                </h6>
                <p class="text-muted small mb-2">
                  {{ operation.patient.name }} {{ operation.patient.firstName }}
                </p>
                <p class="small mb-2">Date: {{ operation.dateOperation|date('Y-m-d H:i') }}</p>
                <div class="mt-auto">
                  <span class="badge bg-primary">Médecins: {{ operation.medecins|length }}</span>
                  <span class="badge bg-info text-dark">Infirmières: {{ operation.infirmieres|length }}</span>
                </div>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>

      {% if total_pages > 1 %}
        <nav aria-label="Page navigation" class="mt-4">
          <ul class="pagination">
            {% if current_page > 1 %}
              <li class="page-item"><a class="page-link" href="{{ path('app_operation', {page: current_page-1}) }}">Précédent</a></li>
            {% endif %}
            <li class="page-item disabled"><span class="page-link">Page {{ current_page }}/{{ total_pages }}</span></li>
            {% if current_page < total_pages %}
              <li class="page-item"><a class="page-link" href="{{ path('app_operation', {page: current_page+1}) }}">Suivant</a></li>
            {% endif %}
          </ul>
        </nav>
      {% endif %}
    {% endif %}
  {% endif %}
</div>

{% block scripts %}
{{ parent() }}
<script>
(function(){
  const api = '{{ path('app_operation') }}';
  const searchBtn = document.getElementById('searchBtn');
  const resultsEl = document.getElementById('results');

  function renderEmpty(text){ resultsEl.innerHTML = '<div class="alert alert-secondary">'+text+'</div>'; }
  function renderError(text){ resultsEl.innerHTML = '<div class="alert alert-danger">'+text+'</div>'; }

  function renderCards(items){
    if(!Array.isArray(items) || items.length===0){ renderEmpty('Aucun résultat.'); return; }
    const row = document.createElement('div');
    row.className = 'row g-3';

    items.forEach(o => {
      const col = document.createElement('div');
      col.className = 'col-md-4';
      const card = document.createElement('div');
      card.className = 'card h-100';
      card.innerHTML = `
        <div class="card-body d-flex flex-column">
          <h6 class="card-title mb-1"><a href="/operation/${o.id}">${o.titre || ''}</a></h6>
          <p class="text-muted small mb-2">${o.patient?.name || ''} ${o.patient?.firstName || ''}</p>
          <p class="small mb-2">Date: ${o.date || ''}</p>
          <div class="mt-auto">
            <span class="badge bg-primary">Médecins: ${o.medecins || 0}</span>
            <span class="badge bg-info text-dark">Infirmières: ${o.infirmieres || 0}</span>
          </div>
        </div>
      `;
      col.appendChild(card);
      row.appendChild(col);
    });

    resultsEl.innerHTML = '';
    resultsEl.appendChild(row);
  }

  function doSearch(){
    const params = new URLSearchParams();
    const q = document.getElementById('q').value.trim();
    const dateFrom = document.getElementById('date_from').value;
    const dateTo = document.getElementById('date_to').value;

    if(q) params.set('q', q);
    if(dateFrom) params.set('date_from', dateFrom);
    if(dateTo) params.set('date_to', dateTo);

    resultsEl.innerHTML = '<div class="text-center py-4"><div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div></div>';

    fetch(api + '?' + params.toString(), { headers: { 'Accept': 'application/json' } })
      .then(r => {
        if(!r.ok) throw new Error('Network error');
        return r.json();
      })
      .then(renderCards)
      .catch(e => { console.error(e); renderError('Erreur lors de la recherche.'); });
  }

  searchBtn.addEventListener('click', doSearch);
  document.getElementById('q').addEventListener('keydown', function(e){ if(e.key==='Enter'){ e.preventDefault(); doSearch(); }});
})();
</script>
{% endblock %}
{% endblock %}
