{% extends 'base.html.twig' %}

{% block title %}Administration - Patients{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Gestion des Patients</h1>
        <div class="d-flex gap-2">
            <a href="{{ path('app_admin_pannel') }}" class="btn btn-outline-secondary">Retour au portail</a>
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#patientModal" onclick="openCreateModal()">
                Créer un patient
            </button>
        </div>
    </div>

    <div id="alertContainer"></div>

    <div class="card">
        <div class="card-body">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nom</th>
                        <th>Prénom</th>
                        <th>Email</th>
                        <th>Ville</th>
                        <th>État</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for patient in patients %}
                    <tr>
                        <td>{{ patient.id }}</td>
                        <td>{{ patient.name }}</td>
                        <td>{{ patient.firstName }}</td>
                        <td>{{ patient.user ? patient.user.email : '-' }}</td>
                        <td>{{ patient.ville }}</td>
                        <td>
                            <span class="badge bg-{{ patient.alive ? 'success' : 'danger' }}">{{ patient.alive ? 'Vivant' : 'Décédé' }}</span>
                        </td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-warning" onclick="openEditModal({{ patient.id }}, '{{ patient.name|e('js') }}', '{{ patient.firstName|e('js') }}', '{{ patient.user ? patient.user.email|e('js') : '' }}', '{{ patient.ville|e('js') }}', {{ patient.alive ? 'true' : 'false' }})">Modifier</button>
                            <button class="btn btn-sm btn-danger" onclick="deletePatient({{ patient.id }}, '{{ patient.name|e('js') }} {{ patient.firstName|e('js') }}')">Supprimer</button>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="7" class="text-center text-muted">Aucun patient trouvé</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="patientModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="patientModalLabel">Créer un patient</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="patientForm">
                    <input type="hidden" id="patientId" value="">

                    <div class="mb-3">
                        <label for="patientName" class="form-label">Nom</label>
                        <input type="text" class="form-control" id="patientName" required>
                    </div>

                    <div class="mb-3">
                        <label for="patientFirstName" class="form-label">Prénom</label>
                        <input type="text" class="form-control" id="patientFirstName" required>
                    </div>

                    <div class="mb-3">
                        <label for="patientVille" class="form-label">Ville</label>
                        <input type="text" class="form-control" id="patientVille" required>
                    </div>

                    <div class="mb-3">
                        <label for="patientEmail" class="form-label">Email</label>
                        <input type="email" class="form-control" id="patientEmail" required>
                    </div>

                    <div class="mb-3">
                        <label for="patientPassword" class="form-label">Mot de passe</label>
                        <input type="password" class="form-control" id="patientPassword">
                        <small class="form-text text-muted" id="patientPasswordHint" style="display:none;">Laissez vide pour conserver le mot de passe actuel</small>
                    </div>

                    <div class="mb-3">
                        <label for="patientAlive" class="form-label">État</label>
                        <select id="patientAlive" class="form-select" required>
                            <option value="1">Vivant</option>
                            <option value="0">Décédé</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                <button type="button" class="btn btn-primary" onclick="savePatient()">Enregistrer</button>
            </div>
        </div>
    </div>
</div>

<script>
let isEditMode = false;

function openCreateModal() {
    isEditMode = false;
    document.getElementById('patientModalLabel').textContent = 'Créer un patient';
    document.getElementById('patientForm').reset();
    document.getElementById('patientId').value = '';
    document.getElementById('patientAlive').value = '1';
    document.getElementById('patientPassword').required = true;
    document.getElementById('patientPasswordHint').style.display = 'none';
}

function openEditModal(id, name, firstName, email, ville, alive) {
    isEditMode = true;
    document.getElementById('patientModalLabel').textContent = 'Modifier un patient';
    document.getElementById('patientId').value = id;
    document.getElementById('patientName').value = name;
    document.getElementById('patientFirstName').value = firstName;
    document.getElementById('patientEmail').value = email;
    document.getElementById('patientVille').value = ville;
    document.getElementById('patientAlive').value = alive ? '1' : '0';
    document.getElementById('patientPassword').value = '';
    document.getElementById('patientPassword').required = false;
    document.getElementById('patientPasswordHint').style.display = 'block';

    const modal = new bootstrap.Modal(document.getElementById('patientModal'));
    modal.show();
}

function savePatient() {
    const patientId = document.getElementById('patientId').value;
    const name = document.getElementById('patientName').value;
    const firstName = document.getElementById('patientFirstName').value;
    const email = document.getElementById('patientEmail').value;
    const password = document.getElementById('patientPassword').value;
    const ville = document.getElementById('patientVille').value;
    const alive = document.getElementById('patientAlive').value;

    if (!name || !firstName || !ville || !email) {
        showAlert('Tous les champs sont requis', 'danger');
        return;
    }

    if (!isEditMode && !password) {
        showAlert('Mot de passe requis', 'danger');
        return;
    }

    const url = isEditMode ? `/admin/patient/${patientId}/update` : '/admin/patient/create';
    const payload = { name, firstName, email, ville, alive: alive === '1' };
    if (password) {
        payload.password = password;
    }

    fetch(url, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify(payload)
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            bootstrap.Modal.getInstance(document.getElementById('patientModal')).hide();
            showAlert(data.message, 'success');
            setTimeout(() => location.reload(), 900);
        } else {
            showAlert(data.message, 'danger');
        }
    })
    .catch(() => showAlert('Erreur lors de la sauvegarde', 'danger'));
}

function deletePatient(id, label) {
    if (!confirm(`Supprimer le patient "${label}" ?`)) {
        return;
    }

    fetch(`/admin/patient/${id}/delete`, { method: 'DELETE' })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                showAlert(data.message, 'success');
                setTimeout(() => location.reload(), 900);
            } else {
                showAlert(data.message, 'danger');
            }
        })
        .catch(() => showAlert('Erreur lors de la suppression', 'danger'));
}

function showAlert(message, type) {
    const alertContainer = document.getElementById('alertContainer');
    const alert = document.createElement('div');
    alert.className = `alert alert-${type} alert-dismissible fade show`;
    alert.role = 'alert';
    alert.innerHTML = `${message}<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>`;
    alertContainer.appendChild(alert);
    setTimeout(() => alert.remove(), 4000);
}
</script>
{% endblock %}
