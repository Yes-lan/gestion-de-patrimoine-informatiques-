{# minimal template qui utilise base.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Recherche Greffe{% endblock %}

{% block body %}
<div class="card shadow-sm">
  <div class="card-body">
    <h5 class="card-title mb-3">Recherche de patients</h5>

    <form id="greffeForm" class="row g-2 align-items-end">
      <div class="col-md-5">
        <label class="form-label visually-hidden" for="q">Nom ou prénom</label>
        <input id="q" name="q" type="search" class="form-control" placeholder="Nom ou prénom">
      </div>

      <div class="col-md-2">
        <label class="form-label visually-hidden" for="status">Statut</label>
        <select id="status" name="status" class="form-select">
          <option value="">Tous</option>
          <option value="need">Besoin de greffe</option>
          <option value="had">A subi une greffe</option>
        </select>
      </div>

      <div class="col-md-3">
        <label class="form-label visually-hidden" for="organ">Organe</label>
        <input id="organ" name="organ" type="text" class="form-control" placeholder="Organe (optionnel)">
      </div>

      <div class="col-md-2 d-grid">
        <button id="searchBtn" type="button" class="btn btn-primary">Rechercher</button>
      </div>

      <div class="col-6 col-md-3">
        <label class="form-label" for="date_from">Depuis</label>
        <input id="date_from" name="date_from" type="date" class="form-control">
      </div>

      <div class="col-6 col-md-3">
        <label class="form-label" for="date_to">jusqu'à</label>
        <input id="date_to" name="date_to" type="date" class="form-control">
      </div>
    </form>
  </div>
</div>

<div id="results" class="mt-4">
  {# render initial patients if passed from controller #}
  {% if patients is defined %}
    {% if patients is empty %}
      <div class="alert alert-secondary">Aucun résultat.</div>
    {% else %}
      <div class="row g-3">
        {% for p in patients %}
          <div class="col-md-4">
            <div class="card h-100">
              <div class="card-body d-flex flex-column">
                <h6 class="card-title mb-1"><a href="{{ path('patient_show', {'id': p.id}) }}">{{ p.name }} {{ p.firstName }}</a></h6>
                <p class="text-muted small mb-2">ID: {{ p.id }}</p>
                <div class="mt-auto">
                  {% set greffe = p.greffes|first %}
                  {% if greffe %}
                    <span class="badge bg-success">Greffe: {{ greffe.type }}</span>
                    <small class="text-muted ms-2">{{ greffe.dateFinDeFonction|date('Y-m-d') }}</small>
                  {% else %}
                    <span class="badge bg-secondary">Pas de greffe</span>
                  {% endif %}
                </div>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>

      {# pagination links #}
      {% if total_pages > 1 %}
        <nav aria-label="Page navigation" class="mt-4">
          <ul class="pagination">
            {% if current_page > 1 %}
              <li class="page-item"><a class="page-link" href="{{ path('app_greffe', {page: current_page-1}) }}">Précédent</a></li>
            {% endif %}
            <li class="page-item disabled"><span class="page-link">Page {{ current_page }}/{{ total_pages }}</span></li>
            {% if current_page < total_pages %}
              <li class="page-item"><a class="page-link" href="{{ path('app_greffe', {page: current_page+1}) }}">Suivant</a></li>
            {% endif %}
          </ul>
        </nav>
      {% endif %}
    {% endif %}
  {% endif %}
</div>

{% block scripts %}
{{ parent() }}
<script>
(function(){
  const api = '{{ path('app_greffe') }}';
  const searchBtn = document.getElementById('searchBtn');
  const resultsEl = document.getElementById('results');

  function renderEmpty(text){ resultsEl.innerHTML = '<div class="alert alert-secondary">'+text+'</div>'; }
  function renderError(text){ resultsEl.innerHTML = '<div class="alert alert-danger">'+text+'</div>'; }

  function renderCards(items){
    if(!Array.isArray(items) || items.length===0){ renderEmpty('Aucun résultat.'); return; }
    const row = document.createElement('div');
    row.className = 'row g-3';
      items.forEach(p=>{
      const col = document.createElement('div');
      col.className = 'col-md-4';
      const card = document.createElement('div');
      card.className = 'card h-100';
      // prepare greffes HTML (support both `greffes` array and legacy `greffe` single)
      let greffesHtml = '';
      if (Array.isArray(p.greffes) && p.greffes.length) {
        greffesHtml = '<ul class="list-unstyled mb-0">';
        p.greffes.forEach(g => {
          const organ = (g.type || g.organ || '');
          const date = (g.date || g.dateFinDeFonction || '');
          greffesHtml += `<li><span class="badge bg-success me-2">${organ}</span><small class="text-muted">${date}</small></li>`;
        });
        greffesHtml += '</ul>';
      } else if (p.greffe) {
        const organ = (p.greffe.type || p.greffe.organ || '');
        const date = (p.greffe.date || p.greffe.dateFinDeFonction || '');
        greffesHtml = `<span class="badge bg-success">Greffe: ${organ}</span> <small class="text-muted ms-2">${date}</small>`;
      } else {
        greffesHtml = '<span class="badge bg-secondary">Pas de greffe</span>';
      }

      card.innerHTML = `
        <div class="card-body d-flex flex-column">
          <h6 class="card-title mb-1"><a href="/patient/${p.id}">${(p.name||p.nom||'')}${(p.firstName||p.prenom)? ' ' + (p.firstName||p.prenom) : ''}</a></h6>
          <p class="text-muted small mb-2">ID: ${p.id||''}${p.date_naissance? ' — Né(e): '+(p.date_naissance||'') : ''}</p>
          <div class="mt-auto">
            ${greffesHtml}
          </div>
        </div>
      `;
      col.appendChild(card);
      row.appendChild(col);
    });
    resultsEl.innerHTML = '';
    resultsEl.appendChild(row);
  }

  function doSearch(){
    const params = new URLSearchParams();
    const q = document.getElementById('q').value.trim();
    const status = document.getElementById('status').value;
    const organ = document.getElementById('organ').value.trim();
    const dateFrom = document.getElementById('date_from').value;
    const dateTo = document.getElementById('date_to').value;
    if(q) params.set('q', q);
    if(status) params.set('status', status);
    if(organ) params.set('organ', organ);
    if(dateFrom) params.set('date_from', dateFrom);
    if(dateTo) params.set('date_to', dateTo);

    resultsEl.innerHTML = '<div class="text-center py-4"><div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div></div>';

    fetch(api + '?' + params.toString(), { headers: { 'Accept': 'application/json' } })
      .then(r => {
        if(!r.ok) throw new Error('Network error');
        return r.json();
      })
      .then(renderCards)
      .catch(e => { console.error(e); renderError('Erreur lors de la recherche.'); });
  }

  searchBtn.addEventListener('click', doSearch);
  document.getElementById('q').addEventListener('keydown', function(e){ if(e.key==='Enter'){ e.preventDefault(); doSearch(); }});
})();
</script>
{% endblock %}
{% endblock %}