{% extends 'base.html.twig' %}

{% block title %}Patient {{ patient.name }} {{ patient.firstName }}{% endblock %}

{% block body %}
<div class="container mt-4">
  <h1>Patient: {{ patient.name }} {{ patient.firstName }}</h1>
  <ul class="list-group mb-3">
    <li class="list-group-item"><strong>Numéro dossier:</strong> {{ patient.id }}</li>
    <li class="list-group-item"><strong>Ville:</strong> {{ patient.ville }}</li>
    <li class="list-group-item">
      <strong>État:</strong> 
      {% if patient.isAlive %}
        <span class="badge bg-success">Vivant</span>
      {% else %}
        <span class="badge bg-danger">Décédé</span>
      {% endif %}
    </li>
  </ul>

  <h2>Greffes</h2>
  {% if patient.greffes is empty %}
    <p>Aucune greffe enregistrée pour ce patient.</p>
  {% else %}
    <div class="list-group">
      {% for g in patient.greffes %}
        <div class="list-group-item">
          <strong>Type:</strong> {{ g.type }}<br>
          <strong>Fonctionnel:</strong> {{ g.fonctionnel ? 'Oui' : 'Non' }}<br>
          <strong>Date fin de fonction:</strong> {{ g.dateFinDeFonction ? g.dateFinDeFonction|date('Y-m-d') : '-' }}
        </div>
      {% endfor %}
    </div>
  {% endif %}

  {% set now = date() %}
  {% set operationsPrevues = patient.operations|filter(o => o.dateOperation and o.dateOperation >= now) %}
  {% set operationsEffectuees = patient.operations|filter(o => o.dateOperation and o.dateOperation < now) %}

  <h2 class="mt-4">Opérations prévues</h2>
  {% if operationsPrevues is empty %}
    <p>Aucune opération prévue.</p>
  {% else %}
    <div class="list-group mb-3">
      {% for operation in operationsPrevues %}
        <a href="{{ path('operation_afficher', {id: operation.id}) }}" class="list-group-item list-group-item-action">
          <strong>{{ operation.titre }}</strong><br>
          <small class="text-muted">Date prévue : {{ operation.dateOperation|date('d/m/Y H:i') }}</small>
        </a>
      {% endfor %}
    </div>
  {% endif %}

  <h2>Opérations déjà effectuées</h2>
  {% if operationsEffectuees is empty %}
    <p>Aucune opération déjà effectuée.</p>
  {% else %}
    <div class="list-group">
      {% for operation in operationsEffectuees %}
        <a href="{{ path('operation_afficher', {id: operation.id}) }}" class="list-group-item list-group-item-action">
          <strong>{{ operation.titre }}</strong><br>
          <small class="text-muted">Date : {{ operation.dateOperation|date('d/m/Y H:i') }}</small>
        </a>
      {% endfor %}
    </div>
  {% endif %}

  <div class="d-flex flex-wrap gap-2 mt-3">
    <a class="btn btn-secondary" href="{{ path('app_greffe') }}">Retour à la liste</a>
    <a class="btn btn-primary" href="{{ path('patient_export', {'id': patient.id}) }}">Télécharger la fiche (DOCX)</a>
</div>
</div>
{% endblock %}
