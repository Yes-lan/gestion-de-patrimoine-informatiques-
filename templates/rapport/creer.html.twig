{% extends 'base.html.twig' %}

{% block title %}Créer un rapport - {{ operation.titre }}{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="row">
        <div class="col-md-10">
            <h1 class="mb-4">
                <i class="bi bi-file-text"></i> Nouveau Rapport
            </h1>
            
            <div class="alert alert-info" role="alert">
                <strong>Opération:</strong> {{ operation.titre }}<br>
                <strong>Patient:</strong> {{ operation.patient.name }} {{ operation.patient.firstName }}
            </div>

            <div class="card shadow-sm">
                <div class="card-body">
                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                    <div class="mb-3">
                        <label class="form-label" for="{{ form.titre.vars.id }}">
                            <strong>{{ form_label(form.titre) }}</strong>
                        </label>
                        {{ form_widget(form.titre) }}
                        {% if form.titre.vars.help %}
                            <small class="form-text text-muted d-block mt-1">
                                {{ form.titre.vars.help }}
                            </small>
                        {% endif %}
                        {{ form_errors(form.titre) }}
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="{{ form.contenuHtml.vars.id }}">
                            <strong>{{ form_label(form.contenuHtml) }}</strong>
                        </label>
                        
                        {# Toolbar pour l'édition riche #}
                        <div class="btn-toolbar mb-2" role="toolbar">
                            <div class="btn-group me-2" role="group">
                                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="formatText('bold')" title="Gras (Ctrl+B)">
                                    <i class="bi bi-type-bold"></i> <strong>Gras</strong>
                                </button>
                                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="formatText('italic')" title="Italique">
                                    <i class="bi bi-type-italic"></i> <em>Italique</em>
                                </button>
                                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="formatText('underline')" title="Souligné">
                                    <i class="bi bi-type-underline"></i> <u>Souligné</u>
                                </button>
                            </div>
                            <div class="btn-group me-2" role="group">
                                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="formatText('formatBlock', 'h2')" title="Titre">
                                    <i class="bi bi-type-h2"></i> H2
                                </button>
                                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="formatText('formatBlock', 'h3')" title="Sous-titre">
                                    <i class="bi bi-type-h3"></i> H3
                                </button>
                            </div>
                            <div class="btn-group me-2" role="group">
                                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="formatText('insertUnorderedList')" title="Liste à puces">
                                    <i class="bi bi-list-ul"></i> Listes
                                </button>
                                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="formatText('insertOrderedList')" title="Liste numérotée">
                                    <i class="bi bi-list-ol"></i> Numérotée
                                </button>
                            </div>
                            <div class="btn-group me-2" role="group">
                                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="formatText('undo')" title="Annuler">
                                    <i class="bi bi-arrow-counterclockwise"></i> Annuler
                                </button>
                                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="formatText('redo')" title="Refaire">
                                    <i class="bi bi-arrow-clockwise"></i> Refaire
                                </button>
                            </div>
                        </div>

                        {# Textarea contenteditable qui remplace l'éditeur riche #}
                        <div id="editor" class="form-control editor-area">
                            {# Placeholder text #}
                        </div>
                        
                        {# Hidden input pour stocker le HTML #}
                        {{ form_widget(form.contenuHtml, {'attr': {'style': 'display: none;'}}) }}
                        
                        {% if form.contenuHtml.vars.help %}
                            <small class="form-text text-muted d-block mt-1">
                                {{ form.contenuHtml.vars.help }}
                            </small>
                        {% endif %}
                        {{ form_errors(form.contenuHtml) }}
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="{{ form.statut.vars.id }}">
                            <strong>{{ form_label(form.statut) }}</strong>
                        </label>
                        {{ form_widget(form.statut) }}
                        {{ form_errors(form.statut) }}
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-start">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-save"></i> Enregistrer le rapport
                        </button>
                        <a href="{{ path('rapport_liste', {operationId: operation.id}) }}" class="btn btn-secondary">
                            <i class="bi bi-x"></i> Annuler
                        </a>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .editor-area {
        min-height: 300px;
        max-height: 600px;
        overflow-y: auto;
        padding: 12px;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        font-size: 14px;
        line-height: 1.6;
        border: 1px solid #dee2e6;
        border-radius: 0.375rem;
    }

    .editor-area:focus {
        outline: none;
        border-color: #80bdff;
        box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.25);
    }

    .editor-area h2 {
        font-size: 1.5rem;
        font-weight: bold;
        margin: 1rem 0 0.5rem;
    }

    .editor-area h3 {
        font-size: 1.25rem;
        font-weight: bold;
        margin: 0.8rem 0 0.4rem;
    }

    .editor-area ul, .editor-area ol {
        margin-left: 2rem;
        margin-bottom: 0.5rem;
    }

    .editor-area li {
        margin-bottom: 0.25rem;
    }

    .btn-toolbar {
        border: 1px solid #dee2e6;
        padding: 8px;
        border-radius: 0.375rem;
        background-color: #f8f9fa;
    }
</style>

<script>
// Synchroniser l'éditeur avec le textarea caché
const editor = document.getElementById('editor');
const hiddenInput = document.getElementById('{{ form.contenuHtml.vars.id }}');

// Charger le contenu initial s'il existe
if (hiddenInput.value) {
    editor.innerHTML = hiddenInput.value;
}

// Mettre à jour le textarea caché quand l'éditeur change
editor.addEventListener('input', function() {
    hiddenInput.value = editor.innerHTML;
});

// Fonction pour formater le texte
function formatText(command, value = null) {
    document.execCommand(command, false, value);
    editor.focus();
    hiddenInput.value = editor.innerHTML;
}

// Soumettre le formulaire
document.querySelector('form').addEventListener('submit', function(e) {
    // S'assurer que le HTML est synchronisé
    hiddenInput.value = editor.innerHTML;
});
</script>
{% endblock %}
